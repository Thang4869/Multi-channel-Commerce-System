// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USERS & AUTH ============
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  fullName  String
  phone     String
  roles     String[] @default(["CUSTOMER"])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  refreshTokens RefreshToken[]
  orders        Order[]
  deliveries    Delivery[]
  warehouseStaff WarehouseStaff[]
  storeStaff    StoreStaff[]
  notifications Notification[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ============ PRODUCTS & CATEGORIES ============
model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Brand {
  id        String   @id @default(cuid())
  name      String
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("brands")
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String   @db.Text
  price       Decimal  @db.Decimal(12, 2)
  categoryId  String
  brandId     String
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category       Category            @relation(fields: [categoryId], references: [id])
  brand          Brand               @relation(fields: [brandId], references: [id])
  orderItems     OrderItem[]
  warehouseStock WarehouseStock[]
  storeStock     StoreStock[]
  inventory      InventoryTransaction[]

  @@index([categoryId])
  @@index([brandId])
  @@map("products")
}

// ============ ORDERS ============
model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique @default(uuid())
  customerId      String
  shippingAddress String
  billingAddress  String?
  totalPrice      Decimal  @db.Decimal(12, 2)
  status          String   @default("PENDING")
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer User        @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  delivery Delivery?

  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal  @db.Decimal(12, 2)
  subtotal  Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ============ WAREHOUSE ============
model Warehouse {
  id         String   @id @default(cuid())
  name       String
  location   String
  capacity   Int
  currentLoad Int     @default(0)
  managerId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  manager        WarehouseStaff?
  stocks         WarehouseStock[]
  transactions   InventoryTransaction[]
  distributions  WarehouseDistribution[]

  @@map("warehouses")
}

model WarehouseStaff {
  id          String   @id @default(cuid())
  userId      String   @unique
  warehouseId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@map("warehouse_staff")
}

model WarehouseStock {
  id           String   @id @default(cuid())
  warehouseId  String
  productId    String
  quantity     Int      @default(0)
  reserved     Int      @default(0)
  available    Int      @db.Computed("quantity - reserved", {mode: "stored"})
  lastRestocked DateTime?
  updatedAt    DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([warehouseId, productId])
  @@index([warehouseId])
  @@index([productId])
  @@map("warehouse_stocks")
}

// ============ STORE ============
model Store {
  id        String   @id @default(cuid())
  name      String
  location  String
  type      String   @default("RETAIL") // RETAIL, POS, ONLINE
  managerId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  manager    StoreStaff?
  stocks     StoreStock[]
  distributions WarehouseDistribution[]

  @@map("stores")
}

model StoreStaff {
  id        String   @id @default(cuid())
  userId    String   @unique
  storeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("store_staff")
}

model StoreStock {
  id            String   @id @default(cuid())
  storeId       String
  productId     String
  quantity      Int      @default(0)
  minThreshold  Int      @default(10)
  lastUpdated   DateTime @updatedAt

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([storeId, productId])
  @@index([storeId])
  @@index([productId])
  @@map("store_stocks")
}

// ============ INVENTORY & WAREHOUSE DISTRIBUTION ============
model InventoryTransaction {
  id          String   @id @default(cuid())
  warehouseId String
  productId   String
  quantity    Int
  type        String   // INBOUND, OUTBOUND, TRANSFER, ADJUSTMENT
  referenceId String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@index([warehouseId])
  @@index([productId])
  @@index([type])
  @@map("inventory_transactions")
}

model WarehouseDistribution {
  id                String   @id @default(cuid())
  warehouseId       String
  storeId           String
  productId         String
  quantity          Int
  status            String   @default("PENDING") // PENDING, IN_TRANSIT, DELIVERED
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  store     Store     @relation(fields: [storeId], references: [id])

  @@index([warehouseId])
  @@index([storeId])
  @@index([status])
  @@map("warehouse_distributions")
}

// ============ DELIVERY ============
model Delivery {
  id                    String   @id @default(cuid())
  orderId               String   @unique
  shipperId             String?
  status                String   @default("PENDING")
  currentLocationLat    Decimal? @db.Decimal(10, 8)
  currentLocationLng    Decimal? @db.Decimal(11, 8)
  currentLocationAddress String?
  destLocationLat       Decimal  @db.Decimal(10, 8)
  destLocationLng       Decimal  @db.Decimal(11, 8)
  destLocationAddress   String
  estimatedDeliveryTime DateTime
  actualDeliveryTime    DateTime?
  notes                 String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shipper User?  @relation(fields: [shipperId], references: [id])
  tracking DeliveryTracking[]

  @@index([orderId])
  @@index([shipperId])
  @@index([status])
  @@map("deliveries")
}

model DeliveryTracking {
  id           String   @id @default(cuid())
  deliveryId   String
  lat          Decimal  @db.Decimal(10, 8)
  lng          Decimal  @db.Decimal(11, 8)
  address      String?
  status       String
  notes        String?  @db.Text
  timestamp    DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@map("delivery_tracking")
}

// ============ NOTIFICATIONS ============
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}
