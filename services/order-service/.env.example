# Order Service Configuration
NODE_ENV=development
PORT=3002

# Database
DATABASE_URL=postgresql://postgres:password@postgres:5432/commerce_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=15m

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3010,http://localhost:8080

# Redis
REDIS_URL=redis://redis:6379

# Logger
LOG_LEVEL=debug

# External Services
AUTH_SERVICE_URL=http://auth-service:3001
INVENTORY_SERVICE_URL=http://inventory-service:3004
NOTIFICATION_SERVICE_URL=http://notification-service:3008
